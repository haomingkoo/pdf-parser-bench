# ============================================================
# PDF Parsing Sandbox — .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
.Python
build/
dist/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Downloaded models (large binary files — download via scripts/) ---
# Docling models (downloaded on first run to ~/.cache/docling/)
# TrOCR models (downloaded on first run to ~/.cache/huggingface/)
# PaddleOCR models (downloaded on first run to ~/.paddleocr/)
# Do not commit model weights — they are 100MB–1.5GB each
*.bin
*.safetensors
*.onnx
*.pkl
*.pt
*.pth

# --- Test data (may contain PII if using real complaint forms) ---
# COMMIT: data/raw/.gitkeep (empty placeholder)
# COMMIT: data/ground_truth/.gitkeep
# IGNORE: actual PDFs and annotated ground truth (may contain PII)
data/raw/**/*.pdf
data/raw/**/*.png
data/raw/**/*.jpg
data/raw/**/*.jpeg
data/raw/**/*.tiff
data/ground_truth/**/*.json
# Exception: synthetic samples generated by download_datasets.py can be committed
# Uncomment to allow: !data/raw/synthetic_*

# --- Evaluation results (generated, large) ---
results/*.jsonl
results/*.csv
results/*.json
# Exception: keep summary reports if manually curated
# !results/summary_final.csv

# --- Jupyter ---
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/
*.ipynb~

# --- Docker ---
.docker/

# --- Secrets / credentials ---
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V2
.Trashes

# --- Editor ---
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# --- Logs ---
*.log
logs/

# --- Temporary files from preprocessing ---
data/raw/**/*_preprocessed.pdf
data/raw/**/*_deskewed.pdf
data/raw/_funsd_raw/
